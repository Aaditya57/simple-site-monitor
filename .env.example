# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://monitor:monitor@localhost:5432/monitor

# ── Redis (required for BullMQ) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
SESSION_COOKIE_DOMAIN=localhost

# ── Admin bootstrap (creates first admin on startup if none exists) ───────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234567

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true and fill in credentials to send email alerts.
# Leave false to run without email (alerts will be logged to console only).
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=smtp_password
SMTP_FROM="Uptime Monitor <alerts@example.com>"

# ── Captcha ──────────────────────────────────────────────────────────────────
# Set to 'true' to enable captcha verification on signup and login.
# Leave 'false' for local dev / self-hosted installs without a captcha key.
CAPTCHA_ENABLED=false
# Provider: 'hcaptcha' or 'recaptcha' (only used when CAPTCHA_ENABLED=true)
CAPTCHA_PROVIDER=hcaptcha
CAPTCHA_SECRET=your_captcha_server_secret
# CAPTCHA_SITE_KEY goes in the frontend .env (apps/web/.env)

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10

# ── Monitor limits & defaults ─────────────────────────────────────────────────
MAX_MONITORS_PER_USER=50
DEFAULT_TLS_WARN_DAYS=10
DEFAULT_CHECK_INTERVAL=10

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
